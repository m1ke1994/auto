# Core
DJANGO_ENV=development
DJANGO_SECRET_KEY=local-development-only-change-me
DJANGO_DEBUG=True
DJANGO_SERVE_MEDIA_FILES=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,backend
DJANGO_REQUIRE_HTTPS=False
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_TRUST_X_FORWARDED_PROTO=False
DJANGO_USE_X_FORWARDED_HOST=False
TIME_ZONE=Europe/Moscow
LOG_LEVEL=INFO
BACKEND_PORT=8000
FRONTEND_PORT=8001
PUBLIC_SITE_PORT=5173
HTTP_PORT=80
ADDITIONAL_SERVER_NAMES=
NGINX_CLIENT_MAX_BODY_SIZE=100m

# Database
DATABASE_URL=
DB_ENGINE=sqlite
POSTGRES_DB=yadro_db
POSTGRES_USER=yadro_user
POSTGRES_PASSWORD=local_yadro_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# SQLite fallback (used when DB_ENGINE=sqlite)
SQLITE_NAME=db.sqlite3

# Redis / Celery
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# CORS / CSRF
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOW_CREDENTIALS=False
PUBLIC_API_CORS_ALLOW_ALL=True
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8001
CORS_ALLOWED_ORIGIN_REGEXES=
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8001

# API / Pagination / JWT
PAGE_SIZE=20
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Rate limits
RATE_LIMIT_PUBLIC_LEAD=60/minute
RATE_LIMIT_PUBLIC_EVENT=120/minute
RATE_LIMIT_PUBLIC_ANALYTICS_EVENT=300/minute
RATE_LIMIT_PUBLIC_TELEGRAM_WEBHOOK=120/minute

# Public URLs
DOMAIN=localhost
SITE_BASE_URL=http://localhost:8000
PUBLIC_BASE_URL=http://localhost:8000
PUBLIC_SITE_DEFAULT_DOMAIN=localhost:3000
PUBLIC_SITE_DEFAULT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:8001
API_URL=http://localhost:8000/api
ADMIN_URL=http://localhost:8000/admin
SEO_AUDIT_USER_AGENT=TrackNode SEO Audit/1.0 (+http://localhost:8000)

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=TrackNode_bot
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_BIND_TOKEN_MAX_AGE=3600
# Telegram delivery mode
# direct = backend sends messages directly to Telegram Bot API
# relay = backend sends messages to external telegram-relay service
TELEGRAM_DELIVERY_MODE=direct
TELEGRAM_RELAY_URL=
TELEGRAM_RELAY_TOKEN=

# Billing (YooKassa)
ENABLE_BILLING=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=http://localhost:8001/mini
PAYMENT_RETURN_URL=http://localhost:8001/mini
PAYMENT_CHECKOUT_URL=

# AI
OPENAI_API_KEY=
OPENAI_MODEL_SEO=gpt-5-mini
OPENAI_MODEL_CONVERSION=gpt-5-mini
AI_RECOMMENDATIONS_ENABLED=False
AI_RECOMMENDATIONS_TIMEOUT_SECONDS=180
AI_RECOMMENDATIONS_TTL_SECONDS=10800
AI_RECOMMENDATIONS_MAX_OUTPUT_TOKENS=900
AI_RECOMMENDATIONS_MAX_OUTPUT_TOKENS_SEO=2200
AI_RECOMMENDATIONS_MAX_OUTPUT_TOKENS_CONVERSION=900
AI_RECOMMENDATIONS_MAX_OUTPUT_TOKENS_RETRY_CAP=3200

# Tracker frontend integration examples
NUXT_PUBLIC_TRACKNODE_TRACKER_SRC=http://localhost:8000/tracker.js
NUXT_PUBLIC_TRACKNODE_API_KEY=

# Optional bootstrap admin
SUPERUSER_EMAIL=
SUPERUSER_PASSWORD=
SUPERUSER_USERNAME=
MEDITATION_USER_EMAIL=
MEDITATION_USER_PASSWORD=
MEDITATION_USER_USERNAME=
MEDITATION_SITE_DOMAIN=localhost:5173
AMEDIA_OWNER_EMAIL=
AMEDIA_OWNER_PASSWORD=
AMEDIA_OWNER_USERNAME=
AMEDIA_SITE_DOMAIN=localhost:3000

# Optional demo site seed
DEMO_SITE_NAME=A Meditation
DEMO_SITE_SLUG=a-meditation
DEMO_SITE_DOMAIN=localhost:3000
DEMO_SITE_API_KEY=
DEMO_PUBLIC_SITE_DIR=
RUN_SEED_DEMO_DATA=0

# Optional Volga / Novaya Konakova site seed
RUN_SEED_VOLGA_SITE=0
VOLGA_PUBLIC_DIR=/volga-public
VOLGA_PUBLIC_DIR_HOST=../volga/frontend/public

# Volga / Novaya Konakova public frontend
VOLGA_SITE_PORT=3001
VOLGA_SITE_VITE_API_URL=https://tracknode.ru/api
VOLGA_SITE_VITE_BACKEND_URL=https://tracknode.ru
VOLGA_SITE_VITE_SITE_URL=https://novoe-konakovo.ru
VOLGA_SITE_VITE_PUBLIC_SITE_URL=https://novoe-konakovo.ru
VOLGA_SITE_VITE_SITE_SLUG=novaya-konakova

# Frontend
VITE_API_URL=http://127.0.0.1:8000/api
VITE_BACKEND_URL=http://127.0.0.1:8000
VITE_SITE_URL=http://localhost:8001
VITE_PUBLIC_SITE_URL=http://localhost:8001
VITE_SITE_NAME=TrackNode
VITE_SITE_DESCRIPTION=TrackNode объединяет аналитику сайтов, лиды, SEO-аудит и отчёты в одном кабинете.
VITE_FAVICON_URL=http://localhost:8001/favicon.svg
VITE_OG_IMAGE_URL=http://localhost:8001/og-image.svg
# Backward-compatible alias; prefer VITE_BACKEND_URL.
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_SITE_SLUG=a-meditation
