# Copy to ydro/.env on the server and replace all CHANGE_ME values.

# Core
DJANGO_ENV=production
DJANGO_ENV_FILE=.env
DJANGO_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
DJANGO_DEBUG=False
DJANGO_SERVE_MEDIA_FILES=False
DJANGO_ALLOWED_HOSTS=tracknode.ru,www.tracknode.ru
DJANGO_REQUIRE_HTTPS=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_TRUST_X_FORWARDED_PROTO=True
DJANGO_USE_X_FORWARDED_HOST=True
TIME_ZONE=Europe/Moscow
LOG_LEVEL=INFO
HTTP_PORT=80
HTTPS_PORT=443
ADDITIONAL_SERVER_NAMES=www.tracknode.ru
NGINX_CLIENT_MAX_BODY_SIZE=100m

# Database
DB_ENGINE=postgres
DATABASE_URL=
POSTGRES_DB=tracknode
POSTGRES_USER=tracknode
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# CORS / CSRF
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOW_CREDENTIALS=False
PUBLIC_API_CORS_ALLOW_ALL=True
CORS_ALLOWED_ORIGINS=https://tracknode.ru,https://www.tracknode.ru,https://leelabird.ru,https://www.leelabird.ru
CORS_ALLOWED_ORIGIN_REGEXES=
CSRF_TRUSTED_ORIGINS=https://tracknode.ru,https://www.tracknode.ru,https://leelabird.ru,https://www.leelabird.ru

# Public URLs for first HTTP launch
DOMAIN=tracknode.ru
SITE_BASE_URL=https://tracknode.ru
PUBLIC_BASE_URL=https://tracknode.ru
PUBLIC_SITE_DEFAULT_DOMAIN=leelabird.ru
PUBLIC_SITE_DEFAULT_URL=https://leelabird.ru
FRONTEND_URL=https://tracknode.ru
API_URL=https://tracknode.ru/api
ADMIN_URL=https://tracknode.ru/admin
SEO_AUDIT_USER_AGENT=TrackNode SEO Audit/1.0 (+https://tracknode.ru)

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=TrackNode_bot
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_BIND_TOKEN_MAX_AGE=3600
# direct = backend sends messages directly to Telegram Bot API
TELEGRAM_DELIVERY_MODE=relay
TELEGRAM_RELAY_URL=http://45.151.69.84:8080/send-message
TELEGRAM_RELAY_TOKEN=
TELEGRAM_RELAY_BIND_TOKEN=

# Web Push (generate one VAPID key pair; never expose the private key to frontend)
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:admin@tracknode.ru

# Billing
ENABLE_BILLING=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://tracknode.ru/mini
PAYMENT_RETURN_URL=https://tracknode.ru/mini
PAYMENT_CHECKOUT_URL=

# AI
OPENAI_API_KEY=
OPENAI_MODEL_SEO=gpt-5-mini
OPENAI_MODEL_CONVERSION=gpt-5-mini
AI_RECOMMENDATIONS_ENABLED=False
AI_RECOMMENDATIONS_TIMEOUT_SECONDS=180
AI_RECOMMENDATIONS_TTL_SECONDS=10800
AI_RECOMMENDATIONS_MAX_OUTPUT_TOKENS=900
AI_RECOMMENDATIONS_MAX_OUTPUT_TOKENS_SEO=2200
AI_RECOMMENDATIONS_MAX_OUTPUT_TOKENS_CONVERSION=900
AI_RECOMMENDATIONS_MAX_OUTPUT_TOKENS_RETRY_CAP=3200

# Tracker / public site
NUXT_PUBLIC_TRACKNODE_TRACKER_SRC=https://tracknode.ru/tracker.js
NUXT_PUBLIC_TRACKNODE_API_KEY=
MEDITATION_SITE_DOMAIN=leelabird.ru
AMEDIA_SITE_DOMAIN=leelabird.ru
DEMO_SITE_NAME=A Meditation
DEMO_SITE_SLUG=a-meditation
DEMO_SITE_DOMAIN=leelabird.ru
DEMO_SITE_API_KEY=
DEMO_PUBLIC_SITE_DIR=
RUN_SEED_DEMO_DATA=0
RUN_SEED_VOLGA_SITE=0
VOLGA_PUBLIC_DIR=/volga-public
VOLGA_PUBLIC_DIR_HOST=../volga/frontend/public

# Volga / Novaya Konakova build args used by ydro/docker-compose.prod.yml
VOLGA_SITE_VITE_API_URL=https://tracknode.ru/api
VOLGA_SITE_VITE_BACKEND_URL=https://tracknode.ru
VOLGA_SITE_VITE_SITE_URL=https://novoe-konakovo.ru
VOLGA_SITE_VITE_PUBLIC_SITE_URL=https://novoe-konakovo.ru
VOLGA_SITE_VITE_SITE_SLUG=novaya-konakova

# A Meditation build args used by ydro/docker-compose.prod.yml
PUBLIC_SITE_VITE_API_URL=https://tracknode.ru/api
PUBLIC_SITE_VITE_BACKEND_URL=https://tracknode.ru
PUBLIC_SITE_VITE_SITE_URL=https://leelabird.ru
PUBLIC_SITE_VITE_PUBLIC_SITE_URL=https://leelabird.ru
PUBLIC_SITE_VITE_SITE_SLUG=a-meditation

# Optional bootstrap admin
SUPERUSER_EMAIL=
SUPERUSER_PASSWORD=
SUPERUSER_USERNAME=
MEDITATION_USER_EMAIL=
MEDITATION_USER_PASSWORD=
MEDITATION_USER_USERNAME=
AMEDIA_OWNER_EMAIL=
AMEDIA_OWNER_PASSWORD=
AMEDIA_OWNER_USERNAME=
